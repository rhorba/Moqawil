# ======================================================
# Moqawil — Environment Configuration
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ======================================================

# ── Database ───────────────────────────────────────────
# Full PostgreSQL connection URL
DATABASE_URL=postgresql://moqawil:changeme@localhost:5432/moqawil

# Docker Compose Postgres credentials (must match DATABASE_URL above)
POSTGRES_USER=moqawil
POSTGRES_PASSWORD=changeme

# ── Auth.js v5 ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/)
# Leave empty to disable Google sign-in
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Resend email magic link (https://resend.com/)
# Leave empty to disable email sign-in
AUTH_RESEND_KEY=

# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Domain for Caddy reverse proxy (production)
APP_DOMAIN=localhost

# ── BAM Exchange Rate ──────────────────────────────────
# How many days to cache the Bank Al-Maghrib rate
# bkam.ma is scraped daily — manual entry used as fallback
BAM_RATE_CACHE_DAYS=1

# ── E2E Testing ────────────────────────────────────────
# Random secret that enables a test-only Credentials provider.
# NEVER set in production. Leave empty to disable.
E2E_TEST_SECRET=

# ── Email (optional SMTP for invoice delivery) ─────────
# Leave empty — email features gracefully degrade without it
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@moqawil.ma
